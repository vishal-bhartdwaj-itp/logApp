{
  "title": "Error Rates by Service",
  "uid": "logapp-error-rates",
  "description": "Error and critical log rates for all ingested services. Use this to spot which external services are throwing the most errors.",
  "tags": ["logapp", "errors"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-90d", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "service",
        "label": "Service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\"}, service)",
        "query": "label_values({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\"}, service)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Error Rate by Service (logs/min)",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (service) (count_over_time({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\", service=~\"$service\", level=~\"ERROR|CRITICAL\"}[1m]))",
          "legendFormat": "{{service}}",
          "refId": "A"
        }
      ],
      "options": { "tooltip": { "mode": "multi" } },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": { "lineWidth": 2 },
          "color": { "mode": "palette-classic" }
        }
      }
    },
    {
      "id": 2,
      "title": "Error Count (last hour)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 0, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\", service=~\"$service\", level=\"ERROR\"}[1h]))",
          "legendFormat": "ERROR",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 5 }, { "color": "red", "value": 20 }]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "Critical Count (last hour)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 8, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\", service=~\"$service\", level=\"CRITICAL\"}[1h]))",
          "legendFormat": "CRITICAL",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 1 }, { "color": "red", "value": 5 }]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "title": "Warning Count (last hour)",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 5, "w": 8, "x": 16, "y": 10 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\", service=~\"$service\", level=\"WARNING\"}[1h]))",
          "legendFormat": "WARNING",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 10 }, { "color": "orange", "value": 50 }]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 5,
      "title": "Recent Errors & Criticals",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 15, "w": 24, "x": 0, "y": 15 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{type=~\"JSON|NGINX|APPEVOLVE|AGENTIC\", service=~\"$service\", level=~\"ERROR|CRITICAL\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "links": [
    { "title": "Ingested Logs", "url": "/d/logapp-ingested-logs", "type": "link" },
    { "title": "Pipeline Health", "url": "/d/logapp-pipeline-health", "type": "link" }
  ]
}