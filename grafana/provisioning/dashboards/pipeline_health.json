{
  "title": "LogApp Pipeline Health",
  "uid": "logapp-pipeline-health",
  "description": "LogApp pipeline metrics: throughput, parse failures, agentic parser usage, queue depth, and Loki push health.",
  "tags": ["logapp", "metrics"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-30m", "to": "now" },
  "timezone": "browser",
  "panels": [
    {
      "id": 1,
      "title": "Logs Processed / sec",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(processed_logs_total[1m])",
          "legendFormat": "processed/sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(parse_failures_total[1m])",
          "legendFormat": "failures/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "failures/sec" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      }
    },
    {
      "id": 2,
      "title": "Agentic Parser Usage",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(unknown_logs_total[1m])",
          "legendFormat": "unknown sent to agent/sec",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "rate(agentic_parsed_total[1m])",
          "legendFormat": "agent parsed/sec",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } }
      }
    },
    {
      "id": 3,
      "title": "Total Processed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "processed_logs_total",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "green" } } }
    },
    {
      "id": 4,
      "title": "Parse Failures",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "parse_failures_total",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 5,
      "title": "Agentic Parsed",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "agentic_parsed_total",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "short", "color": { "mode": "fixed", "fixedColor": "blue" } } }
    },
    {
      "id": 6,
      "title": "Loki Push Failures",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "loki_push_failures_total",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": {
        "defaults": { "unit": "short" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [
              { "id": "thresholds", "value": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] } },
              { "id": "color", "value": { "mode": "thresholds" } }
            ]
          }
        ]
      }
    },
    {
      "id": 7,
      "title": "Raw Queue Size",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 8 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "raw_queue_size",
          "refId": "A"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "minVizWidth": 75 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
          "max": 50000,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 10000 },
              { "color": "red", "value": 40000 }
            ]
          }
        }
      }
    },
    {
      "id": 8,
      "title": "Log Processing Latency (p50 / p95 / p99)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(log_processing_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(log_processing_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.99, rate(log_processing_seconds_bucket[1m]))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 9,
      "title": "Loki Push Latency (p50 / p95)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.50, rate(loki_push_duration_seconds_bucket[1m]))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, rate(loki_push_duration_seconds_bucket[1m]))",
          "legendFormat": "p95",
          "refId": "B"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 10,
      "title": "LogApp Runtime Logs",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{source=\"runtime_logs\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": false,
        "showLabels": false,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": true
      }
    }
  ],
  "links": [
    { "title": "Ingested Logs", "url": "/d/logapp-ingested-logs", "type": "link" },
    { "title": "Error Rates", "url": "/d/logapp-error-rates", "type": "link" }
  ]
}