{
  "title": "AppEvolve Log Analytics",
  "uid": "logapp-appevolve",
  "description": "Deep analytics for AppEvolve logs — log levels, active loggers, error tracking, and message explorer.",
  "tags": ["logapp", "appevolve"],
  "editable": true,
  "schemaVersion": 39,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-7d", "to": "now" },
  "timezone": "browser",
  "templating": {
    "list": [
      {
        "name": "level",
        "label": "Log Level",
        "type": "query",
        "datasource": { "type": "loki", "uid": "loki" },
        "definition": "label_values({type=\"APPEVOLVE\"}, level)",
        "query": "label_values({type=\"APPEVOLVE\"}, level)",
        "refresh": 2,
        "includeAll": true,
        "allValue": ".+",
        "multi": true,
        "sort": 1,
        "hide": 0,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Total Logs",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        }
      }
    },
    {
      "id": 2,
      "title": "ERROR Count",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\", level=\"ERROR\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 100 },
              { "color": "red", "value": 1000 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 3,
      "title": "WARNING Count",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\", level=\"WARNING\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 50 },
              { "color": "orange", "value": 500 }
            ]
          },
          "color": { "mode": "thresholds" }
        }
      }
    },
    {
      "id": 4,
      "title": "INFO Count",
      "type": "stat",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\", level=\"INFO\"}[$__range]))",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "green" }
        }
      }
    },
    {
      "id": 5,
      "title": "Log Volume by Level",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 14, "x": 0, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum by (level) (count_over_time({type=\"APPEVOLVE\", level=~\"$level\"}[$__interval]))",
          "legendFormat": "{{level}}",
          "refId": "A",
          "interval": "30m"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] },
          { "matcher": { "id": "byName", "options": "INFO" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "green" } }] },
          { "matcher": { "id": "byName", "options": "DEBUG" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "blue" } }] },
          { "matcher": { "id": "byName", "options": "CRITICAL" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "dark-red" } }] }
        ]
      }
    },
    {
      "id": 6,
      "title": "Error & Warning Rate",
      "type": "timeseries",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 10, "x": 14, "y": 4 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\", level=\"ERROR\"}[$__interval]))",
          "legendFormat": "ERROR",
          "refId": "A",
          "interval": "30m"
        },
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "sum(count_over_time({type=\"APPEVOLVE\", level=\"WARNING\"}[$__interval]))",
          "legendFormat": "WARNING",
          "refId": "B",
          "interval": "30m"
        }
      ],
      "options": {
        "tooltip": { "mode": "multi" },
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["sum", "max"] }
      },
      "fieldConfig": {
        "defaults": { "unit": "short", "custom": { "lineWidth": 2, "fillOpacity": 15 } },
        "overrides": [
          { "matcher": { "id": "byName", "options": "ERROR" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "red" } }] },
          { "matcher": { "id": "byName", "options": "WARNING" }, "properties": [{ "id": "color", "value": { "mode": "fixed", "fixedColor": "orange" } }] }
        ]
      }
    },
    {
      "id": 7,
      "title": "Top 10 Most Active Loggers",
      "type": "bargauge",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by (metadata_logger) (count_over_time({type=\"APPEVOLVE\"} | json[$__range])))",
          "legendFormat": "{{metadata_logger}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "palette-classic" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "blue", "value": null }] }
        }
      }
    },
    {
      "id": 8,
      "title": "Top 10 Error-Generating Loggers",
      "type": "bargauge",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "topk(10, sum by (metadata_logger) (count_over_time({type=\"APPEVOLVE\", level=\"ERROR\"} | json[$__range])))",
          "legendFormat": "{{metadata_logger}}",
          "refId": "A"
        }
      ],
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "orientation": "horizontal",
        "displayMode": "gradient",
        "valueMode": "color"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "red" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": null }] }
        }
      }
    },
    {
      "id": 9,
      "title": "Recent Errors & Warnings",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 20 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{type=\"APPEVOLVE\", level=~\"ERROR|WARNING\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    },
    {
      "id": 10,
      "title": "Log Explorer",
      "type": "logs",
      "datasource": { "type": "loki", "uid": "loki" },
      "gridPos": { "h": 15, "w": 24, "x": 0, "y": 32 },
      "targets": [
        {
          "datasource": { "type": "loki", "uid": "loki" },
          "expr": "{type=\"APPEVOLVE\", level=~\"$level\"}",
          "refId": "A"
        }
      ],
      "options": {
        "dedupStrategy": "none",
        "enableLogDetails": true,
        "prettifyLogMessage": true,
        "showLabels": true,
        "showTime": true,
        "sortOrder": "Descending",
        "wrapLogMessage": false
      }
    }
  ],
  "links": [
    { "title": "Ingested Logs", "url": "/d/logapp-ingested-logs", "type": "link" },
    { "title": "Error Rates", "url": "/d/logapp-error-rates", "type": "link" },
    { "title": "Pipeline Health", "url": "/d/logapp-pipeline-health", "type": "link" }
  ]
}